<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lp100a.App.ViewModels"
        x:Class="Lp100a.App.Views.SetupWindow"
        x:DataType="vm:SetupViewModel"
        Width="400" SizeToContent="Height"
        CanResize="False" ShowInTaskbar="False"
        Background="{StaticResource BgBrush}"
        Icon="/Assets/app-icon.png"
        Title="LP-100A Setup">

  <StackPanel Margin="16" Spacing="10">

    <!-- Connection -->
    <TextBlock Text="CONNECTION" FontWeight="Bold" Foreground="{StaticResource BlueBrush}"/>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <ComboBox ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}"
                MinWidth="150" PlaceholderText="Port"/>
      <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
      <Button Content="{Binding ConnectLabel}" Command="{Binding ConnectCommand}"/>
    </StackPanel>
    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" TextWrapping="Wrap"/>

    <Border Height="1" Background="{StaticResource PanelBrush}"/>

    <!-- Display -->
    <TextBlock Text="DISPLAY" FontWeight="Bold" Foreground="{StaticResource BlueBrush}"/>
    <TextBlock Text="Keep the LP-100A on its Watts screen for live power/vector data."
               Foreground="{StaticResource DimBrush}" TextWrapping="Wrap" FontSize="12"/>
    <UniformGrid Columns="2">
      <CheckBox Content="Forward power bar" IsChecked="{Binding Display.ShowPowerBar}" Margin="0,3"/>
      <CheckBox Content="SWR bar"          IsChecked="{Binding Display.ShowSwrBar}" Margin="0,3"/>
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3">
        <CheckBox Content="Peak forward" IsChecked="{Binding Display.ShowPeak}"/>
        <Button Content="(reset)" Command="{Binding ResetPeakCommand}"
                Background="Transparent" BorderThickness="0" Padding="0"
                Foreground="{StaticResource BlueBrush}" Cursor="Hand" VerticalAlignment="Center"/>
      </StackPanel>
      <CheckBox Content="dBm"              IsChecked="{Binding Display.ShowDbm}" Margin="0,3"/>
      <CheckBox Content="Reflected power"  IsChecked="{Binding Display.ShowReflected}" Margin="0,3"/>
      <CheckBox Content="Return loss"      IsChecked="{Binding Display.ShowReturnLoss}" Margin="0,3"/>
      <CheckBox Content="TX timer"         IsChecked="{Binding Display.ShowTx}" Margin="0,3"/>
      <CheckBox Content="Meter mode"       IsChecked="{Binding Display.ShowMeterMode}" Margin="0,3"/>
      <CheckBox Content="Meter alarm"      IsChecked="{Binding Display.ShowMeterAlarm}" Margin="0,3"/>
      <CheckBox Content="|Z| magnitude"    IsChecked="{Binding Display.ShowZ}" Margin="0,3"/>
      <CheckBox Content="Phase"            IsChecked="{Binding Display.ShowPhase}" Margin="0,3"/>
      <CheckBox Content="R + jX"           IsChecked="{Binding Display.ShowRx}" Margin="0,3"/>
    </UniformGrid>

    <Border Height="1" Background="{StaticResource PanelBrush}"/>

    <StackPanel Spacing="4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <CheckBox Content="Peak hold" IsChecked="{Binding Display.PeakHoldEnabled}" VerticalAlignment="Center"/>
        <TextBlock Text="decay" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
        <NumericUpDown Value="{Binding Display.PeakHoldSeconds}" Minimum="0.25" Maximum="5.0"
                       Increment="0.25" FormatString="0.00" Width="124" VerticalAlignment="Center"
                       IsEnabled="{Binding Display.PeakHoldEnabled}"/>
        <TextBlock Text="s" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
      </StackPanel>
      <UniformGrid Columns="2">
        <CheckBox Content="Show vector window" IsChecked="{Binding Display.ShowVectorWindow}" Margin="0,3"/>
        <CheckBox Content="Always on top"      IsChecked="{Binding Display.AlwaysOnTop}" Margin="0,3"/>
      </UniformGrid>
    </StackPanel>

    <Border Height="1" Background="{StaticResource PanelBrush}"/>

    <!-- SWR alarm -->
    <TextBlock Text="SWR ALARM" FontWeight="Bold" Foreground="{StaticResource BlueBrush}"/>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Meter setpoint" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
      <Button Content="{Binding AlarmSetpointText}" Command="{Binding CycleAlarmCommand}"
              FontFamily="Consolas" FontWeight="Bold" Foreground="{StaticResource BlueBrush}"
              Background="Transparent" BorderThickness="0" Padding="14,2" Cursor="Hand"
              VerticalAlignment="Center" MinWidth="60"/>
    </StackPanel>
    <CheckBox Content="Show on-screen SWR alarm" IsChecked="{Binding Display.SwrBannerEnabled}"/>
    <TextBlock Text="Cycling the setpoint drives the meter's own alarm and relay. The on-screen banner echoes it. Note: the meter doesn't report a value for its User setpoint, so the banner can't show for User or Off — the meter's alarm still works."
               Foreground="{StaticResource DimBrush}" TextWrapping="Wrap" FontSize="12"/>

    <Border Height="1" Background="{StaticResource PanelBrush}"/>

    <!-- Updates -->
    <TextBlock Text="UPDATES" FontWeight="Bold" Foreground="{StaticResource BlueBrush}"/>
    <StackPanel Orientation="Horizontal" Spacing="10">
      <Button Content="Check for updates" Command="{Binding CheckUpdatesCommand}"
              IsVisible="{Binding !UpdateAvailable}"/>
      <Button Content="Update now" Command="{Binding UpdateNowCommand}"
              IsVisible="{Binding UpdateAvailable}"/>
      <CheckBox Content="Check at startup" IsChecked="{Binding CheckUpdatesAtStartup}" VerticalAlignment="Center"/>
    </StackPanel>
    <TextBlock Text="{Binding UpdateStatus}" Foreground="{Binding UpdateStatusBrush}" TextWrapping="Wrap"/>
    <Button Content="Open releases page" Command="{Binding OpenReleaseCommand}"
            Background="Transparent" BorderThickness="0" Padding="0"
            Foreground="{StaticResource BlueBrush}" Cursor="Hand" HorizontalAlignment="Left"/>

  </StackPanel>
</Window>
